# Tragen Sie hier den Link zu Ihrem öffentlichen ICS-Kalender ein.
# Beispiel: Ein öffentlicher Kalender im ICS Format
ICS_URL=https://calendar.google.com/calendar/ical/your-calendar-id/public/basic.ics

# Link zum Geburtstags-Kalender (ebenfalls als ICS-Link)
BIRTHDAY_ICS_URL=https://calendar.google.com/calendar/ical/your-birthday-calendar-id/public/basic.ics

# Spotify Integration (Erstelle eine App unter developer.spotify.com)
SPOTIPY_CLIENT_ID=your_spotify_client_id
SPOTIPY_CLIENT_SECRET=your_spotify_client_secret
SPOTIPY_REDIRECT_URI=https://localhost:5000/callback

# Google Maps API (für Fahrtzeiten & Verkehr)
GOOGLE_MAPS_API_KEY=dein_api_key_hier
